-- Simple Noclip logic
local function updateNoclip()
    if noclipConn then
        noclipConn:Disconnect()
        noclipConn = nil
    end

    if isNoclip then
        noclipConn = RunService.Heartbeat:Connect(function()
            if not player.Character then return end
            local char = player.Character
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then
                    part.CanCollide = false
                end
            end
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum:ChangeState(Enum.HumanoidStateType.Physics)
            end
        end)
        table.insert(connectionStorage, noclipConn)
    end
end

-- Rounded corners helper
function createRoundedCorners(parent, radius)
    local corner = Instance.new("UICorner", parent)
    corner.CornerRadius = radius or UDim.new(0, 0)
    return corner
end

-- Glow helper (purple neon outline + pulse when active)
local function createGlow(parent, enabled)
    local stroke = parent:FindFirstChildOfClass("UIStroke")
    if stroke then stroke:Destroy() end

    if enabled then
        stroke = Instance.new("UIStroke")
        stroke.Color = Color3.fromRGB(200, 0, 255)  -- bright purple
        stroke.Thickness = 2.5
        stroke.Transparency = 0.3
        stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        stroke.LineJoinMode = Enum.LineJoinMode.Round
        stroke.Parent = parent

        -- Subtle pulse animation (optional - remove if you want static glow)
        TweenService:Create(stroke, TweenInfo.new(1.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {
            Transparency = 0.1
        }):Play()
    end
end

